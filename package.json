{
  "name": "sun-hierarchy",
  "version": "1.0.1",
  "description": "A library for hierarchy graph layout based on sugiyama framework",
  "keywords": [
    "hierarchy",
    "graph",
    "layout",
    "sugiyama"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist/**/*"
  ],
  "directories": {
    "test": "test"
  },
  "scripts": {
    "test": "nyc mocha --require ts-node/register --require tsconfig-paths/register src/test/*.ts",
    "test:svg": "mocha --require ts-node/register --require tsconfig-paths/register src/test/*.ts && echo '\n✅ SVG files generated in svg-output/ — open svg-output/index.html to browse'",
    "test-single": "nyc mocha --require ts-node/register --require tsconfig-paths/register",
    "build": "tsc --project tsconfig.json && tsc-alias -p tsconfig.json",
    "format": "prettier --write \"src/**/*.ts\"",
    "lint": "eslint \"src/**/*.ts\"",
    "lint:fix": "eslint \"src/**/*.ts\" --fix",
    "prepare": "husky && pnpm run build",
    "prepublishOnly": "pnpm run test",
    "version": "pnpm run format && git add -A src",
    "postversion": "git push && git push --tags"
  },
  "lint-staged": {
    "src/**/*.ts": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "nyc": {
    "extension": [
      ".ts",
      ".tsx"
    ],
    "exclude": [
      "**/*.d.ts",
      "coverage/",
      "dist/",
      "src/utils/vertex.ts",
      "src/utils/penaltyGraph.ts",
      "src/test/helpers/**",
      "src/docs/**"
    ],
    "all": true
  },
  "author": "sylsaint",
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^9.24.0",
    "@types/chai": "^5.2.2",
    "@types/dagre": "^0.7.54",
    "@types/lodash": "^4.17.16",
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.5.0",
    "chai": "^4.5.0",
    "dagre": "^0.8.5",
    "eslint": "^9.24.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.1",
    "mocha": "^11.2.2",
    "nyc": "^17.1.0",
    "prettier": "^3.5.3",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.8.11",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.29.1"
  },
  "dependencies": {
    "lodash": "^4.17.21"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sylsaint/sun-hierarchy.git"
  }
}
